# ── Encryption ────────────────────────────────────────────────────────────────
# Master key that wraps per-user SQLCipher DEKs (generate: openssl rand -hex 32)
# LOSING THIS KEY MAKES ALL USER DATA UNRECOVERABLE. Store an offline backup.
DB_ENCRYPTION_MASTER_KEY=change_me

# ── Data ──────────────────────────────────────────────────────────────────────
# Per-device encrypted DBs live at DATA_DIR/users/<uid>/workouts.db;
# the identity DB is DATA_DIR/users.db.
DATA_DIR=./data

# ── Server ────────────────────────────────────────────────────────────────────
BACKEND_PORT=8001
FRONTEND_PORT=5173

# ── Strava (dormant — shelved, code kept) ─────────────────────────────────────
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:5173/auth/callback
